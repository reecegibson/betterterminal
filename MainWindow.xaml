<Window x:Class="BetterTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BetterTerminal.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="BetterTerminal"
        Width="1100" Height="700"
        MinWidth="600" MinHeight="400"
        Background="{StaticResource BgBrush}"
        WindowStyle="None"
        ResizeMode="CanResize">

    <!--
        WindowChrome removes OS title-bar chrome and lets WPF own
        the entire window surface.  CaptionHeight makes row 0 the
        drag region; buttons inside it set IsHitTestVisibleInChrome=True
        so they intercept clicks instead of dragging.
    -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <!--
        Single grid with shared rows AND columns.
        Row 0 = title bar (36px),  Row 1 = content.
        Columns match sidebar / divider / main — so the title bar
        sections are perfectly flush with what's directly below them.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="140" MaxWidth="320"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TITLE BAR — left cell (sidebar-coloured, shows app name)
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource SidebarBrush}">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="14,0">
                <TextBlock Text="›_"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="11"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="BetterTerminal"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Title bar — divider cell (continues the vertical separator) -->
        <Rectangle Grid.Row="0" Grid.Column="1"
                   Fill="{StaticResource SepBrush}"/>

        <!-- ══════════════════════════════════════════════════════════
             TITLE BAR — right cell (main-coloured, holds win controls)
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="2"
                Background="{StaticResource SidebarBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch">

                <!-- Minimise -->
                <Button Style="{StaticResource TitleBarBtn}"
                        FontSize="12"
                        Content="─"
                        ToolTip="Minimise"
                        Click="MinimizeButton_Click"/>

                <!-- Maximise / Restore — content toggles via trigger -->
                <Button FontSize="10"
                        ToolTip="Maximise / Restore"
                        Click="MaximizeButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
                            <Setter Property="Content" Value="□"/>
                            <Style.Triggers>
                                <DataTrigger Value="Maximized"
                                             Binding="{Binding WindowState,
                                                       RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Setter Property="Content" Value="❐"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Close -->
                <Button Style="{StaticResource CloseTitleBarBtn}"
                        FontSize="11"
                        Content="✕"
                        ToolTip="Close"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             SIDEBAR  (row 1, col 0)
             ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Grid.Column="0"
              Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>      <!-- session list -->
                <RowDefinition Height="Auto"/>   <!-- new-session btn -->
            </Grid.RowDefinitions>

            <!-- Session list -->
            <ListBox x:Name="SessionList"
                     Grid.Row="0"
                     AllowDrop="True"
                     PreviewMouseLeftButtonDown="SessionList_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="SessionList_PreviewMouseMove"
                     DragOver="SessionList_DragOver"
                     Drop="SessionList_Drop"
                     DragLeave="SessionList_DragLeave"
                     ItemsSource="{Binding Sessions}"
                     SelectedItem="{Binding ActiveSession, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="False">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"                    Value="0"/>
                        <Setter Property="Margin"                     Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SessionViewModel}">
                        <Border x:Name="Row"
                                Height="36"
                                Cursor="Hand"
                                Background="Transparent"
                                Tag="{Binding DataContext,
                                      RelativeSource={RelativeSource AncestorType=Window}}">

                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Rename"
                                              Command="{Binding PlacementTarget.Tag.RequestRenameCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="Close"
                                              Command="{Binding PlacementTarget.Tag.CloseSessionCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Border.ContextMenu>

                            <Grid Margin="10,0,6,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <!-- Colored icon (emoji / Nerd Font glyph).
                                         Collapsed when SessionViewModel.Icon is null. -->
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="13"
                                               Foreground="White"
                                               Margin="0,0,5,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DisplayTitle}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <Grid Grid.Column="1" Width="18" Height="18">
                                    <Ellipse x:Name="StatusDot"
                                             Width="8" Height="8"
                                             Fill="#E81224"/>
                                    <Button x:Name="CloseBtn"
                                            Content="✕"
                                            FontSize="10"
                                            Width="18" Height="18"
                                            Padding="0"
                                            Style="{StaticResource GhostBtn}"
                                            Visibility="Hidden"
                                            ToolTip="Close"
                                            Command="{Binding DataContext.CloseSessionCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <DataTemplate.Triggers>
                            <DataTrigger Value="True"
                                         Binding="{Binding IsSelected,
                                                   RelativeSource={RelativeSource AncestorType=ListBoxItem}}">
                                <Setter TargetName="Row" Property="Background"
                                        Value="{StaticResource ActiveBrush}"/>
                            </DataTrigger>
                            <DataTrigger Value="True" Binding="{Binding IsActive}">
                                <Setter TargetName="StatusDot" Property="Fill" Value="#16C60C"/>
                            </DataTrigger>
                            <Trigger SourceName="Row" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row"       Property="Background"
                                        Value="{StaticResource HoverBrush}"/>
                                <Setter TargetName="CloseBtn"  Property="Visibility"
                                        Value="Visible"/>
                                <Setter TargetName="StatusDot" Property="Visibility"
                                        Value="Hidden"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Drop indicator overlay — floats above the list, not hit-testable -->
            <Canvas x:Name="DropCanvas"
                    Grid.Row="0"
                    IsHitTestVisible="False"
                    Panel.ZIndex="10">
                <Rectangle x:Name="DropLine"
                           Height="2"
                           Fill="{StaticResource AccentBrush}"
                           Visibility="Collapsed"/>
            </Canvas>

            <!-- New-session button -->
            <Button Grid.Row="1"
                    Content="＋  New Session"
                    Height="40"
                    FontSize="12"
                    Style="{StaticResource GhostBtn}"
                    BorderBrush="{StaticResource SepBrush}"
                    BorderThickness="0,1,0,0"
                    Command="{Binding AddSessionCommand}"/>
        </Grid>

        <!-- Vertical divider (row 1, col 1) -->
        <Rectangle Grid.Row="1" Grid.Column="1"
                   Fill="{StaticResource SepBrush}"/>

        <!-- ══════════════════════════════════════════════════════════
             MAIN TERMINAL AREA  (row 1, col 2)
             EasyTerminalControl instances are added here in code-behind,
             one per session.  Only the active session is Visible; the
             rest stay Hidden so their processes keep running.
             ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="TerminalHost"
              Grid.Row="1" Grid.Column="2"
              Background="{StaticResource BgBrush}"/>
    </Grid>
</Window>
