<Application x:Class="BetterTerminal.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>

        <!-- ── Palette ───────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgBrush"      Color="#0C0C0C"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#141414"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#007ACC"/>
        <SolidColorBrush x:Key="TextBrush"    Color="#CCCCCC"/>
        <SolidColorBrush x:Key="DimBrush"     Color="#858585"/>
        <SolidColorBrush x:Key="HoverBrush"   Color="#2A2D2E"/>
        <SolidColorBrush x:Key="ActiveBrush"  Color="#37373D"/>
        <SolidColorBrush x:Key="SepBrush"     Color="#3C3C3C"/>
        <SolidColorBrush x:Key="InputBgBrush" Color="#2D2D30"/>

        <!-- ── Ghost button (transparent, highlights on hover) ───── -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Accent / primary button ───────────────────────────── -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding"    Value="12,6"/>
        </Style>

        <!-- ── Title-bar window-control buttons ─────────────────────
             TitleBarBtn : min / max  →  subtle gray hover
             CloseTitleBarBtn : close →  red hover (Windows 11 style)
        ──────────────────────────────────────────────────────────── -->
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Width"            Value="46"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBarBtn" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Width"            Value="46"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#981020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ContextMenu ─────────────────────────────────────
             Must replace the entire ControlTemplate — WPF's default
             wraps the popup in SystemDropShadowChrome which ignores
             Background/BorderBrush property setters.
        ──────────────────────────────────────────────────────────── -->
        <Style TargetType="ContextMenu">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#2D2D30"
                                BorderBrush="#555555"
                                BorderThickness="1"
                                Padding="2"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── MenuItem (simple — no submenus needed yet) ────────── -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource DimBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Separator (dark) ──────────────────────────────────── -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource SepBrush}"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0,2"/>
        </Style>

        <!-- ── Modern thin scrollbar ─────────────────────────────
             No arrow buttons. 6 px rounded thumb (10 px track).
             Applied globally — also covers the WPF ScrollBar
             inside Microsoft.Terminal.Wpf's TerminalControl.
        ──────────────────────────────────────────────────────────── -->

        <!-- Thumb: dark pill, brightens on hover / drag -->
        <Style x:Key="ModernScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop"             Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd"
                                Background="#4D4D4D"
                                CornerRadius="3"
                                SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7A7A7A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Zero-height repeat buttons replace the up/down arrow buttons -->
        <ControlTemplate x:Key="ScrollLineBtn" TargetType="RepeatButton">
            <Border Height="0" Width="0"/>
        </ControlTemplate>

        <!-- Transparent repeat buttons fill the track above/below the thumb -->
        <ControlTemplate x:Key="ScrollPageBtn" TargetType="RepeatButton">
            <Border Background="Transparent"/>
        </ControlTemplate>

        <!-- Vertical track template -->
        <ControlTemplate x:Key="VertScrollBar" TargetType="ScrollBar">
            <Border Background="Transparent" SnapsToDevicePixels="True">
                <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Template="{StaticResource ScrollPageBtn}"
                                      Command="ScrollBar.PageUpCommand"
                                      Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ModernScrollThumb}" Margin="2,2"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Template="{StaticResource ScrollPageBtn}"
                                      Command="ScrollBar.PageDownCommand"
                                      Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <!-- Horizontal track template -->
        <ControlTemplate x:Key="HorzScrollBar" TargetType="ScrollBar">
            <Border Background="Transparent" SnapsToDevicePixels="True">
                <Track x:Name="PART_Track" IsDirectionReversed="False" Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Template="{StaticResource ScrollPageBtn}"
                                      Command="ScrollBar.PageLeftCommand"
                                      Focusable="False"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ModernScrollThumb}" Margin="2,2"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Template="{StaticResource ScrollPageBtn}"
                                      Command="ScrollBar.PageRightCommand"
                                      Focusable="False"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <!-- Implicit ScrollBar style (no x:Key → applies everywhere) -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels"   Value="True"/>
            <Setter Property="Width"                 Value="10"/>
            <Setter Property="MinWidth"              Value="10"/>
            <Setter Property="Template"              Value="{StaticResource VertScrollBar}"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template"   Value="{StaticResource HorzScrollBar}"/>
                    <Setter Property="Width"      Value="Auto"/>
                    <Setter Property="MinWidth"   Value="0"/>
                    <Setter Property="Height"     Value="10"/>
                    <Setter Property="MinHeight"  Value="10"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Application.Resources>
</Application>
