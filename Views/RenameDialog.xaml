<Window x:Class="BetterTerminal.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Session"
        Width="320"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="#1E1E1E"
        ShowInTaskbar="False">
    <Grid Margin="16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- label -->
            <RowDefinition Height="6"/>      <!-- gap -->
            <RowDefinition Height="Auto"/>   <!-- TextBox -->
            <RowDefinition Height="14"/>     <!-- gap -->
            <RowDefinition Height="Auto"/>   <!-- buttons -->
            <RowDefinition Height="4"/>      <!-- bottom breath -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Session name"
                   Foreground="#858585"
                   FontSize="11"/>

        <TextBox x:Name="NameBox"
                 Grid.Row="2"
                 Background="#2D2D30"
                 Foreground="#CCCCCC"
                 CaretBrush="#CCCCCC"
                 SelectionBrush="#007ACC"
                 BorderBrush="#007ACC"
                 BorderThickness="1"
                 Padding="8,7"
                 FontSize="13"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Content="Rename"
                    IsDefault="True"
                    Width="80"
                    Margin="0,0,8,0"
                    Padding="0,7"
                    Style="{StaticResource AccentBtn}"
                    Click="OkButton_Click"/>
            <Button Content="Cancel"
                    IsCancel="True"
                    Width="80"
                    Padding="0,7"
                    Background="#3E3E42"
                    Style="{StaticResource GhostBtn}"/>
        </StackPanel>
    </Grid>
</Window>
